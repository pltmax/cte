#!/bin/sh
# Pre-commit: ADR reminder + dead code detection

# Check if architectural files are staged in this commit
ARCH_FILES_CHANGED=$(git diff --cached --name-only 2>/dev/null | grep -E \
  "supabase/migrations/|backend/requirements\.txt|backend/app/routers/|backend/app/models/|backend/app/main\.py|frontend/src/app/api/" \
  | wc -l | tr -d ' ')

if [ "$ARCH_FILES_CHANGED" -gt "0" ]; then
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "ADR REMINDER"
  echo "   Architectural files staged in this commit:"
  git diff --cached --name-only 2>/dev/null | grep -E \
    "supabase/migrations/|backend/requirements\.txt|backend/app/routers/|backend/app/models/|backend/app/main\.py|frontend/src/app/api/" \
    | sed 's/^/   - /'
  echo ""
  echo "   If this represents a significant architectural decision,"
  echo "   create an ADR: use the 'archivist' Claude agent"
  echo "   or add a file to docs/adr/NNN-kebab-case-title.md"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
fi

# Dead code detection

if [ -f frontend/knip.json ]; then
  echo "[pre-commit] Running dead code detection (Knip)..."
  cd frontend
  npx knip --reporter json > ../docs/context/dead_code_report.json 2>/dev/null || true
  cd ..

  # Count dead files
  DEAD_COUNT=$(node -e "
    try {
      const r = JSON.parse(require('fs').readFileSync('docs/context/dead_code_report.json','utf8'));
      const files = (r.files || []).length;
      const exports = Object.keys(r.unlisted || {}).length;
      console.log(files + exports);
    } catch(e) { console.log(0); }
  " 2>/dev/null || echo "0")

  if [ "$DEAD_COUNT" -gt "0" ]; then
    echo ""
    echo "WARNING: $DEAD_COUNT dead code entries detected."
    echo "   Review docs/context/dead_code_report.json before committing."
    echo "   To skip: SKIP_DEAD_CODE=1 git commit ..."
    echo ""
    git add docs/context/dead_code_report.json 2>/dev/null || true
  else
    echo "[pre-commit] No dead code detected."
    git add docs/context/dead_code_report.json 2>/dev/null || true
  fi
fi
