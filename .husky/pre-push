#!/bin/sh
# Pre-push: context regeneration + ADR reminder

echo "[pre-push] Regenerating architectural context..."
HUSKY=1 npm run context:sync

# Check if architectural files were modified in this push
ARCH_FILES_CHANGED=$(git diff origin/main...HEAD --name-only 2>/dev/null | grep -E \
  "supabase/migrations/|backend/requirements\.txt|backend/app/routers/|backend/app/models/|backend/app/main\.py|frontend/src/app/api/" \
  | wc -l | tr -d ' ')

if [ "$ARCH_FILES_CHANGED" -gt "0" ]; then
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "📋 ADR REMINDER"
  echo "   Architectural files were modified in this push:"
  git diff origin/main...HEAD --name-only 2>/dev/null | grep -E \
    "supabase/migrations/|backend/requirements\.txt|backend/app/routers/|backend/app/models/|backend/app/main\.py|frontend/src/app/api/" \
    | sed 's/^/   - /'
  echo ""
  echo "   If this represents a significant architectural decision,"
  echo "   create an ADR: use the 'archivist' Claude agent"
  echo "   or add a file to docs/adr/NNN-kebab-case-title.md"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
fi
