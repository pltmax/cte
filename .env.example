# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Next.js (prefix with NEXT_PUBLIC_ to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Context engineering — DB introspection (Session mode port 5432, NOT 6543)
# Get from: Supabase Dashboard > Settings > Database > Connection pooling > Session mode
DATABASE_URL=postgresql://postgres.[your-project-ref]:[your-db-password]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres

# Supabase project ref (used in .mcp.json)
SUPABASE_PROJECT_REF=your-project-ref

# ElevenLabs (used by scripts/generate_toeic.py)
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Stripe (backend only — never expose secret key to the browser)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
# Get from: Stripe Dashboard > Developers > Webhooks > your endpoint > Signing secret
# For local dev: run `stripe listen --forward-to localhost:8000/api/v1/stripe/webhook`
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Create products/prices at: https://dashboard.stripe.com/products
# Premium plan: recurring, €15/month
STRIPE_PREMIUM_PRICE_ID=price_xxx
# Credit pack: one-time, €6.99
STRIPE_CREDIT_PRICE_ID=price_xxx
# Public URL of the Next.js frontend (used to build Stripe redirect URLs)
APP_URL=http://localhost:3000

# FastAPI backend base URL (used by Next.js Server Actions — never exposed to browser)
API_URL=http://localhost:8000
