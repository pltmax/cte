# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # backend + migrations only

# Next.js (NEXT_PUBLIC_ prefix exposes to the browser — anon key only)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys  (never expose to browser)
STRIPE_SECRET_KEY=sk_test_xxx

# Get from: Stripe Dashboard > Developers > Webhooks > your Vercel endpoint > Signing secret
# For local dev: run `stripe listen --forward-to localhost:3000/api/stripe/webhook`
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Create one-time-payment prices at: https://dashboard.stripe.com/products
STRIPE_RUSH_PRICE_ID=price_xxx      # Rush plan (14 days)
STRIPE_CHILL_PRICE_ID=price_xxx     # Chill plan (30 days)
STRIPE_UPGRADE_PRICE_ID=price_xxx   # Rush → Chill upgrade
STRIPE_CREDIT_PRICE_ID=price_xxx    # Extra credit pack

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# Public URL of the Next.js app — used to build Stripe redirect URLs
APP_URL=http://localhost:3000

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxx
# Address that receives contact-form messages
CONTACT_EMAIL=contact@yourdomain.com
# Sender address — must be a verified domain in Resend.
# While domain is unverified, set this to the email you used to sign up for Resend
# and set CONTACT_EMAIL to that same address (Resend restriction on onboarding@resend.dev).
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── Backend (FastAPI / Railway) ───────────────────────────────────────────────
# Set to "production" on Railway to disable Swagger UI (/docs, /redoc)
ENVIRONMENT=development

# Comma-separated extra CORS origins beyond APP_URL (optional)
# CORS_EXTRA_ORIGINS=https://www.yourdomain.com

# ── Google Cloud Storage ──────────────────────────────────────────────────────
# Bucket name for audio/image assets
GCS_BUCKET_NAME=your-bucket-name
# Service account JSON (one-line, base64-encoded or raw JSON string)
GCS_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ── Context engineering (dev only) ───────────────────────────────────────────
# Session mode port 5432 — get from: Supabase > Settings > Database > Connection pooling
DATABASE_URL=postgresql://postgres.[your-project-ref]:[your-db-password]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres
SUPABASE_PROJECT_REF=your-project-ref

# ── ElevenLabs (scripts only) ─────────────────────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_HALE=wWWn96OtTHu1sn8SRGEr
ELEVENLABS_VOICE_JUDE=Yg7C1g7suzNt5TisIqkZ
ELEVENLABS_VOICE_JESSICA=DbwWo4rVEd5NrejHYUnm
ELEVENLABS_VOICE_BEA=aHCytOTnUOgfGPn5n89j
